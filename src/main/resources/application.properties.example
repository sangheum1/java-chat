spring.application.name=test
server.port=8089
spring.datasource.url=jdbc:mysql://localhost:3306/chat
spring.datasource.username=여기에_DB_아이디
spring.datasource.password=여기에_DB_비밀번호
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# JWT 설정 (운영 환경에서는 환경변수로 오버라이드)
jwt.secret=${JWT_SECRET:여기에_JWT_시크릿키_입력}
jwt.access-expiration=${JWT_ACCESS_EXPIRATION:1800000}
jwt.refresh-expiration=${JWT_REFRESH_EXPIRATION:604800000}

# CORS 허용 오리진
cors.allowed-origins=${CORS_ALLOWED_ORIGINS:http://localhost:3000}

# ===================================================================
# 데일리 로그 파일 자동 생성 및 30일 보관 설정
# ===================================================================

# 1. 오늘 실시간으로 쌓이는 로그 파일의 이름과 위치를 지정합니다 (프로젝트 폴더 내 logs 폴더 안)
logging.file.name=logs/my-app-error.log

# 2. 밤 12시가 지나면 날짜를 붙여서 파일을 새로 쪼개는 규칙입니다 (%d{yyyy-MM-dd}가 데일리를 의미함)
logging.logback.rollingpolicy.file-name-pattern=logs/error-%d{yyyy-MM-dd}.%i.log

# 3. 정확히 30일 동안만 로그 파일을 보관하고, 31일째 되는 날 가장 오래된 파일을 자동으로 삭제합니다
logging.logback.rollingpolicy.max-history=30

# 카카오 OAuth2 설정
kakao.client-id=여기에_카카오_클라이언트_ID
kakao.client-secret=여기에_카카오_클라이언트_시크릿
kakao.redirect-uri=http://localhost:8089/auth/kakaoCallback
